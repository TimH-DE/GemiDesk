{
  "name": "gemidesk",
  "version": "1.2.0",
  "desktopName": "gemidesk.desktop",
  "main": "dist-electron/main/main.js",
  "description": "GemiDesk - Native Desktop Client for Gemini",
  "author": "Tim",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build-nix": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^42.0.1",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.6"
  },
  "build": {
    "appId": "com.timh-de.gemidesk",
    "productName": "GemiDesk",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "assets/icons/logo.png"
    }
  }
}
